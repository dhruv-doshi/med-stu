{"id":"diabetes_followup_001","title":"Type 2 diabetes follow-up","specialty":"General medicine","difficulty":"Beginner","learning_objectives":["Review glycaemic control","Screen for diabetic complications"],"patient_profile":{"name":"Meena","age":52,"personality":"practical and worried","communication_style":"answers clearly when asked"},"presenting_complaint":"Here for a diabetes review; tired and thirsty recently.","facts":[{"id":"duration","text":"The thirst and tiredness have been getting worse over about three months.","matchers":["how long","duration","when","start"],"category":"symptom"},{"id":"glucose","text":"My home sugar readings are often around 250 after meals.","matchers":["sugar","glucose","reading","control"],"category":"monitoring","is_red_flag":true},{"id":"medication","text":"I take metformin but miss it several times a week.","matchers":["medicine","medication","tablet","metformin","adherence"],"category":"medication_history"},{"id":"diet","text":"I have been eating more sweets and do not exercise much lately.","matchers":["diet","food","exercise","lifestyle"],"category":"social_history"},{"id":"neuropathy","text":"I sometimes get tingling in both feet at night.","matchers":["tingling","feet","numb","neuropathy"],"category":"complication","is_red_flag":true},{"id":"vision","text":"My vision occasionally goes blurry.","matchers":["vision","eye","blur"],"category":"complication","is_red_flag":true}],"investigations":[{"id":"hba1c","name":"HbA1c","summary":"HbA1c is 10.2%.","interpretation":"Poor glycaemic control.","recommended":true},{"id":"urine_acr","name":"Urine albumin-creatinine ratio","summary":"Moderately increased albuminuria.","interpretation":"Early diabetic kidney disease risk.","recommended":true}],"expected_differentials":["poorly controlled type 2 diabetes"],"expected_management":["diabetes medication review","lifestyle counselling"],"expected_diagnosis":"poorly controlled type 2 diabetes"}
